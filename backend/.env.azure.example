# Azure App Service → Configuration → Application settings
# Add each of these as a key/value pair (not as a file).

NODE_ENV=production

# Azure sets PORT automatically for containers; leave this out unless you need
# to override the default (8080).
# PORT=8080

# Set to the App Service URL after first deploy, e.g.:
# https://employee-reports.azurewebsites.net
# Leave blank to accept requests from any origin.
CORS_ORIGIN=https://<your-app>.azurewebsites.net

# Path to the seeded Excel file inside the container (do not change).
DATA_FILE=./data/employees.xlsx

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=HR Reports <your-gmail@gmail.com>

# Set to false to send real emails; true to log them without sending.
MAIL_PREVIEW_ONLY=false

# Optional: redirect all outgoing emails to this address (useful for UAT).
# MAIL_TO_OVERRIDE=test@example.com
