# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Data
DATA_FILE=./data/employees.xlsx

# SMTP (Nodemailer) — for the Send Email feature
# Use your own provider: Gmail, Outlook, AWS SES, Mailtrap, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="HR Reports <hr-reports@example.com>"

# Set to "true" to skip actually sending mail (handy for demos / dev)
MAIL_PREVIEW_ONLY=true

# Optional: redirect ALL outbound emails to this address (useful when employee
# emails are fake/sample data and you want to verify delivery in a real inbox)
# MAIL_TO_OVERRIDE=you@example.com
