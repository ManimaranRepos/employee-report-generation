{
  "name": "employee-report-backend",
  "version": "1.0.0",
  "description": "Express + TypeScript backend for the Employee Report Generation System.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "seed": "tsx scripts/generateSampleData.ts",
    "build:index": "tsx scripts/buildIndex.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.15.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
